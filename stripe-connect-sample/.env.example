# ---------------------------
# Stripe Connect sample env
# ---------------------------

# TODO: Replace with your real Stripe secret key from Dashboard > Developers > API keys
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE

# TODO: Set your local base URL where this sample server runs
APP_BASE_URL=http://localhost:4242

# TODO: Supabase project URL (same project used by ThriftUVA app)
SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# TODO: Supabase service role key (required for backend writes from this server)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# TODO: Add webhook secret after running:
# stripe listen --thin-events 'v2.core.account[requirements].updated,v2.core.account[.recipient].capability_status_updated' --forward-thin-to http://localhost:4242/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# Optional: override port (default is 4242)
PORT=4242

# Optional: application fee in basis points (1000 = 10%)
APPLICATION_FEE_BPS=1000
